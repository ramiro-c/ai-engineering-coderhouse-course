LLM_PROVIDER=gemini

# Gemini Developer API (API key) — often hits free-tier 429s
GEMINI_API_KEY=

# Gemini via Vertex AI (recommended if the API key keeps 429'ing)
# Uses Application Default Credentials, not GEMINI_API_KEY.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
